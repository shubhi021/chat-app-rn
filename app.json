{
  "expo": {
    "name": "ChatAppV2",
    "slug": "ChatAppV2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shubhi.chatappv2",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow ChatApp to access your photos to share images in chat.",
        "NSCameraUsageDescription": "Allow ChatApp to use your camera to take photos for chat."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.shubhi.chatappv2",
      "permissions": ["READ_MEDIA_IMAGES", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-status-bar"]
  }
}
